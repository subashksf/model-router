# --- Database ---
POSTGRES_DB=model_router
POSTGRES_USER=router
POSTGRES_PASSWORD=secret
DATABASE_URL=postgresql+asyncpg://router:secret@db:5432/model_router

# --- Provider API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Gateway ---
# Default policy file path (relative to /app/policies inside the container)
DEFAULT_POLICY=default_policy.yaml
# Optional: shared secret for inbound requests
GATEWAY_API_KEY=

# --- Dashboard ---
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
