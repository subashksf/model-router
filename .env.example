# ── Mode ────────────────────────────────────────────────────────────────────
# "mock"  → no API keys needed, data stored in model_router DB
# "real"  → calls live APIs, data stored in model_router_real DB
ROUTER_MODE=mock

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=model_router        # primary DB created by Docker on first run
POSTGRES_USER=router
POSTGRES_PASSWORD=secret

# Per-mode URLs — docker-compose injects these automatically.
# Override here only if you run Postgres outside Docker.
# DATABASE_URL_MOCK=postgresql+asyncpg://router:secret@localhost:5433/model_router
# DATABASE_URL_REAL=postgresql+asyncpg://router:secret@localhost:5433/model_router_real

# ── Provider API Keys ────────────────────────────────────────────────────────
# Required when ROUTER_MODE=real
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...           # optional — only needed if a policy tier uses openai

# ── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000
